# Claude Code local project state (session settings, not a dotfile to share)
.claude/

# History files
.zsh_history
.bash_history
.python_history
.node_repl_history

# Cache directories
.cache/
.npm/
.yarn/

# Logs
*.log

# Sensitive files
# SSH: ignore everything by default, but keep shared config in repo
.ssh/*
!.ssh/config
.gnupg/
.aws/
.kube/

# Omarchy-compatible theme system: generated at theme-switch time from
# templates, never hand-edited. See .config/dunst/dunstrc.tpl and
# .local/bin/omarchy-theme-set-templates.
.config/dunst/dunstrc
.config/kitty/current-theme.conf

# Python bytecode cache from the theme-template renderer
__pycache__/
*.pyc